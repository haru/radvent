- if @board.board_type_user? && @board.visibility_private?
  - content_for(:head) { tag.meta(name: 'robots', content: 'noindex') }

- if @board.board_type_user?
  - content_for(:navbar_breadcrumb) do
    %span.navbar-brand > #{link_to @board.name, board_path(@board.board_id)}

- content_for(:jumbotron) do
  %div#event-header.jumbotron.container-fluid.p-5
    %div.container
      - if @board.board_type_top?
        %h1= system_title
      - else
        %h1= @board.name
        - if @board.description.present?
          %p= @board.description

%div#event-cards
  %div.advent-calendar-description
    %h2= t('views.welcome.index.description_title')
    %hr
    %p= t('views.welcome.index.description')

  - if Event.creatable_on?(@board, current_user)
    = link_to t('boards.show.create_event'), new_event_path(board_id: @board.id), class: 'btn btn-success text-white mb-3'

  %div.row
    - @events.each do |event|
      = link_to show_event_path(event.name), class: "event-card card", style: "width: 30rem;" do
        %div.card-header
          %h4
            %i.far.fa-calendar-alt
            = event.title
          = "#{event.start_date} - #{event.end_date}"
        %div.card-body
          %p.card-text= event.description
        %div.card-footer
          = t('views.welcome.index.entries', entries: event.entry_count, days: event.day_count)
          %div.progress
            %div.progress-bar.bg-success{role: "progressbar", style: "width: #{event.entry_percent}%",
                              "aria-valuenow": event.entry_count,
                              "aria-valuemin": 0, "aria-valuemax": event.day_count}
