- if @board.visibility_private?
  - content_for(:head) { tag.meta(name: 'robots', content: 'noindex') }

- content_for(:header_bar) do
  = render 'shared/breadcrumb', board: @board

- content_for(:content) do
  %div.container.mt-4
    %h1= @board.name
    - if @board.description.present?
      %p.text-muted= @board.description

    %hr

    - if Event.creatable_on?(@board, current_user)
      = link_to t('boards.show.create_event'), new_event_path, class: 'btn btn-success mb-3'

    %div.row
      - @events.each do |event|
        = link_to show_event_path(event.name), class: 'event-card card mb-3', style: 'width: 30rem;' do
          %div.card-header
            %h4
              %i.far.fa-calendar-alt
              = event.title
            = "#{event.start_date} - #{event.end_date}"
          %div.card-body
            %p.card-text= event.description
          %div.card-footer
            = t('views.welcome.index.entries', entries: event.entry_count, days: event.day_count)
